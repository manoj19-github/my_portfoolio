generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
}

model Skill {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  category      String
  proficiency   Int
  display_order Int

  @@map("skills")
}